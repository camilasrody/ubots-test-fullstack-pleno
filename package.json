{
  "name": "ubots-test",
  "private": true,
  "version": "1.0.0",
  "description": "Software de distribuicao e monitoramento de atendimentos FlowPay",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev:api": "npm run dev --workspace api",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run db:generate --workspace api",
    "db:migrate": "npm run db:migrate --workspace api",
    "db:seed": "npm run db:seed --workspace api"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camilasrody/ubots-test-fullstack-pleno.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/camilasrody/ubots-test-fullstack-pleno/issues"
  },
  "homepage": "https://github.com/camilasrody/ubots-test-fullstack-pleno#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.6.2"
  }
}
